# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Chain / RPC ──────────────────────────────────────────────────────────────
RPC_URL="https://eth-rpc-testnet.polkadot.io/"
CHAIN_ID=420420417

# ── Contracts ────────────────────────────────────────────────────────────────
PERP_DEX_ADDRESS="0xa8de3e548054417e4d918FAC46E990aF623AC7BA"
TOKEN_ADDRESS="0x277E42B9454fB36A7Eaa52D4cE332bEF71dd017a"

# ── Keeper wallet (private key – NEVER commit this) ──────────────────────────
KEEPER_PRIVATE_KEY=""

# ── Faucet wallet (optional – falls back to KEEPER_PRIVATE_KEY) ───────────────
FAUCET_PRIVATE_KEY=""

# ── Oracle wallet (optional – falls back to KEEPER_PRIVATE_KEY) ───────────────
# If set, this signer should be authorized as updater in ZenitOracle.
ORACLE_PRIVATE_KEY=""

# ── Price feed ───────────────────────────────────────────────────────────────
PYTH_ENDPOINT="https://hermes.pyth.network"

# Optional: override Pyth Hermes price feed IDs (hex).
# If a feed ID is missing, the keeper will not fetch/publish a price for that market.
PYTH_HBAR_USD_FEED_ID=""
PYTH_SAUCE_USD_FEED_ID=""
PYTH_PACK_USD_FEED_ID=""
PYTH_BONZO_USD_FEED_ID=""

# ── Polling ──────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000

# ── REST API ─────────────────────────────────────────────────────────────────
API_PORT=3100
