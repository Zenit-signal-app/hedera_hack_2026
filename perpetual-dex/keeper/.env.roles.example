# Role-based keeper env template (Hedera testnet setup)
# Copy to keeper/.env and fill private keys by role mapping in ../../roles.json
#
# Recommended key assignment:
# - KEEPER_PRIVATE_KEY  -> wallet index 2 (keeper_close_engine)
# - ORACLE_PRIVATE_KEY  -> wallet index 3 (oracle_updater)
# - FAUCET_PRIVATE_KEY  -> wallet index 4 (faucet_sender)
# - Owner/deployer key  -> wallet index 1 (used in hardhat scripts, not in this file)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Chain / RPC (Hedera testnet EVM RPC) ─────────────────────────────────────
RPC_URL="https://testnet.hashio.io/api"
CHAIN_ID=296

# ── Contracts (fill after deployment) ────────────────────────────────────────
PERP_DEX_ADDRESS=""
TOKEN_ADDRESS=""
ORACLE_ADDRESS=""

# ── Keeper wallet (wallet #2) ────────────────────────────────────────────────
KEEPER_PRIVATE_KEY=""

# ── Faucet wallet (wallet #4) ────────────────────────────────────────────────
FAUCET_PRIVATE_KEY=""
FAUCET_ACCOUNT_ID=""
FAUCET_HTS_TOKEN_ID="0.0.8271323"

# ── Oracle wallet (wallet #3) ────────────────────────────────────────────────
ORACLE_PRIVATE_KEY=""

# ── Price feed ───────────────────────────────────────────────────────────────
PYTH_ENDPOINT="https://hermes.pyth.network"
PYTH_HBAR_USD_FEED_ID="0x3728e591097635310e6341af53db8b7ee42da9b3a8d918f9463ce9cca886dfbd"

# Optional feeds (set only if available on Pyth)
PYTH_SAUCE_USD_FEED_ID=""
PYTH_PACK_USD_FEED_ID=""
PYTH_BONZO_USD_FEED_ID=""

# ── Polling/API ──────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000
API_PORT=3100
