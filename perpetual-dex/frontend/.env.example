# Get projectId from https://cloud.walletconnect.com (required for RainbowKit)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# Contract addresses - Polkadot EVM Testnet (zUSDC as trading + reward token)
# zUSDC: 0x277E42B9454fB36A7Eaa52D4cE332bEF71dd017a
VITE_DEX_ADDRESS=0xfDb613715EAc5a908Dc50d6c517a4044F243a71b
VITE_TOKEN_ADDRESS=0x277E42B9454fB36A7Eaa52D4cE332bEF71dd017a
VITE_REWARD_ADDRESS=0x6fAbdA09fa1FB9e3087Db3De8D3b71E26bE15CA0

# ZUSDCStaking contract (stake zUSDC, earn zUSDC). Set after deployStaking.
# VITE_STAKING_ADDRESS=0x...

# Keeper service URL for TP/SL registration (must be reachable from browser)
# Local dev: http://localhost:3100 | Production: https://your-keeper-domain.com
VITE_KEEPER_URL=http://localhost:3100

# Onramper on-ramp (iframe at /onramp). Get key from Onramper dashboard.
# Docs: https://docs.onramper.com/docs/integration-steps
# VITE_ONRAMPER_API_KEY=

# Optional: Pyth Hermes price feed IDs (hex) used by the frontend.
# If a feed ID is missing, the UI may not show prices for that market.
VITE_PYTH_HBAR_USD_FEED_ID=""
VITE_PYTH_SAUCE_USD_FEED_ID=""
VITE_PYTH_PACK_USD_FEED_ID=""
VITE_PYTH_BONZO_USD_FEED_ID=""

# --- Aggregator /aggregate (Hedera EVM) ---
# Tuỳ chọn: tốc độ quote ~6s — Mirror ít trang + timeout; Quoter V2 có giới hạn; split route thưa.
# VITE_AGGREGATOR_MIRROR_MAX_PAGES=6
# VITE_AGGREGATOR_MIRROR_MAX_WAIT_MS=2800
# VITE_AGGREGATOR_QUOTE_BUDGET_MS=6000
# VITE_AGGREGATOR_V2_QUOTE_MAX_WAIT_MS=3200
# adapterId trên Exchange = TÊN NGẮN (saucerswap, saucerswap_v2) — KHÔNG phải địa chỉ 0x contract adapter
# VITE_AGGREGATOR_NETWORK=testnet
# VITE_AGGREGATOR_NETWORK=mainnet
# Khi đã có địa chỉ token mà router fail: mặc định UI báo lỗi (không mock ẩn). Bật mock: VITE_AGGREGATOR_ALLOW_MOCK_ON_ROUTER_FAIL=1
# VITE_AGGREGATOR_ALLOW_MOCK_ON_ROUTER_FAIL=1
# QuoteAggregator (hoặc Exchange nếu gọi quote trực tiếp):
# VITE_AGGREGATOR_QUOTE_CONTRACT=0x...
# Bắt buộc cho swap on-chain:
# VITE_AGGREGATOR_EXCHANGE_CONTRACT=0x...
# Native HBAR → token qua SaucerSwap V1 `swapExactETHForTokens*` + msg.value (mặc định bật). Tắt: wrap WHBAR + Exchange
# VITE_AGGREGATOR_USE_SAUCE_NATIVE_HBAR_SWAP=0
# HBAR→token: mặc định swapExactETHForTokens. Token HTS phí đặc biệt: VITE_AGGREGATOR_HBAR_TO_TOKEN_SWAP_FN=supporting
# VITE_AGGREGATOR_HBAR_TO_TOKEN_SWAP_FN=supporting
# Id đã setAdapter cho UniswapV2LikeAdapter (V1) — khi UI fallback V1; mặc định trong code = saucerswap
# VITE_AGGREGATOR_V1_ADAPTER_ID=saucerswap
# VITE_AGGREGATOR_QUOTE_CONTRACT=0x...
# Optional: dashboard stats JSON (see src/lib/aggregatorStats.ts)
# VITE_AGGREGATOR_STATS_URL=https://your-api.example.com/v1/aggregator/stats
# Optional: token addresses for on-chain quote (HTS ERC-20 facade)
# Gợi ý USDC/HBAR từ API SaucerSwap + path: `npm run saucerswap:usdc-hbar:env` (repo root) — xem docs/SAUCERSWAP_REST_ENV.md
# VITE_AGGREGATOR_TOKEN_USDC=0x...
# VITE_AGGREGATOR_TOKEN_WHBAR=0x...
# VITE_AGGREGATOR_TOKEN_USDC_MAINNET=0x...
# VITE_AGGREGATOR_TOKEN_WHBAR_MAINNET=0x...
# SAUCE / XSAUCE (optional — mainnet có mặc định entity trong code nếu không set)
# VITE_AGGREGATOR_TOKEN_SAUCE_MAINNET=0x...
# VITE_AGGREGATOR_TOKEN_XSAUCE_MAINNET=0x...
# SaucerSwap V2 QuoterV2 (CLMM) — quote/path; optional override; defaults: mainnet entity 0.0.3949424, testnet 0.0.1390002
# VITE_SAUCERSWAP_V2_QUOTER_MAINNET=0x...
# VITE_SAUCERSWAP_V2_QUOTER_TESTNET=0x...
# SaucerSwap V2 Factory — getPool trước khi quote (mainnet 0.0.3946833, testnet 0.0.1197038)
# VITE_SAUCERSWAP_V2_FACTORY_MAINNET=0x...
# VITE_SAUCERSWAP_V2_FACTORY_TESTNET=0x...
# SaucerSwap V2 SwapRouter — exactInput(bytes path); default mainnet entity 0.0.3949434
# VITE_SAUCERSWAP_V2_SWAP_ROUTER_MAINNET=0x...
# VITE_SAUCERSWAP_V2_SWAP_ROUTER_TESTNET=0x...

# --- Chỉ cho script diagnose (chạy từ `perpetual-dex/`, không phải biến VITE) ---
# Token EVM 0x có pool với cả USDC và WHBAR trên SaucerSwap (ứng viên bridge: USDT, SAUCE, …) — xem `docs/AGGREGATOR.md`
# DIAGNOSE_BRIDGE_TOKEN=0x...

# Hardhat — `hardhat.config.ts` loads this file (run commands from `perpetual-dex/`)
# Mainnet deploy: use a dedicated key (recommended)
# HEDERA_MAINNET_PRIVATE_KEY=0x...
# HEDERA_MAINNET_RPC_URL=https://mainnet.hashio.io/api
# Testnet-only key (optional; else PRIVATE_KEY)
# HEDERA_TESTNET_PRIVATE_KEY=0x...
# HEDERA_TESTNET_RPC_URL=https://testnet.hashio.io/api
# Fallback for any network if the above are unset:
# PRIVATE_KEY=0x...
#
# Optional — deployExchangeStack.ts (UniswapV2LikeAdapter / FixedRateSwapAdapter / UniswapV3SwapRouterAdapter)
# AGGREGATOR_V2_ROUTER=0x...
# ADAPTER_ID_V2=saucerswap   # khớp UI (mặc định); không dùng "v2" trừ khi chỉnh VITE_AGGREGATOR_V1_ADAPTER_ID
# SAUCERSWAP_V3_SWAP_ROUTER=0x...   # SaucerSwap V2 SwapRouter (mainnet entity 0.0.3949434 nếu không override)
# SAUCERSWAP_V3_QUOTER=0x...        # QuoterV2 (cùng docs contract-deployments)
# ADAPTER_ID_V3=saucerswap_v2
# ADAPTER_FEE_BPS=0
# FIXED_ADAPTER_TOKEN_IN=0x...
# FIXED_ADAPTER_TOKEN_OUT=0x...
# FIXED_RATE_NUMERATOR=1000000000000000000
# FIXED_RATE_DENOMINATOR=1000000000000000000
# ADAPTER_ID_FIXED=fixed
