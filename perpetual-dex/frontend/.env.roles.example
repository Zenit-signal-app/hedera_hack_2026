# Role-based frontend env template (Hedera testnet)
# Keep role mapping in ../../roles.json
#
# Wallet roles used here:
# - wallet #1 (deployer_owner) -> PRIVATE_KEY
# - wallet #4 (faucet_sender)  -> VITE_FAUCET_PRIVATE_KEY / VITE_FAUCET_WALLET
#
# Note:
# - PRIVATE_KEY is used by hardhat scripts (deploy/setKeeper/setOracleUpdater).
# - VITE_* variables are used by frontend at runtime.

# Hedera EVM testnet RPC
POLKADOT_TESTNET_RPC_URL=https://testnet.hashio.io/api

# Owner/deployer key (wallet #1)
PRIVATE_KEY=

# Optional metadata
WALLET_ADRESS=

# HTS/ERC20 token address used as zUSDC collateral (set after token creation/selection)
zUSDC_Smartcontract=

# Contract addresses (filled by scripts/deploy.ts output)
VITE_PERP_DEX_ADDRESS=
VITE_DEX_ADDRESS=
VITE_REWARD_ADDRESS=
VITE_TOKEN_ADDRESS=
VITE_ORACLE_ADDRESS=

# Faucet sender (wallet #4)
VITE_FAUCET_PRIVATE_KEY=
VITE_FAUCET_WALLET=

# Keeper API URL (local default)
VITE_KEEPER_URL=http://localhost:3100

# Optional Pyth feed overrides for frontend service
VITE_PYTH_HBAR_USD_FEED_ID=0x3728e591097635310e6341af53db8b7ee42da9b3a8d918f9463ce9cca886dfbd
VITE_PYTH_SAUCE_USD_FEED_ID=
VITE_PYTH_PACK_USD_FEED_ID=
VITE_PYTH_BONZO_USD_FEED_ID=
