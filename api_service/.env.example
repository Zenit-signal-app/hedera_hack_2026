# Example environment variables for Zenit API. Copy to `.env` and fill secrets.

# Application
PROJECT_NAME=Zenit
VERSION=0.1.0
PORT=8000
PROTOCOL=http
DOMAIN=localhost
HOST=localhost
STATIC_FOLDER=./static

# Swagger / docs guard
DOC_PASSWORD=docs_password_here
SESSION_SECRET_KEY=a_long_random_string

# TLS (optional - only used if you run uvicorn with ssl_keyfile/ssl_certfile)
SSL_KEY=
SSL_CERT=

# Database
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/zenit
SCHEMA_1=public
SCHEMA_2=
SCHEMA_3=
SCHEMA_4=
SCHEMA_5=

# JWT / session
ENCODE_KEY=replace_with_random_bytes
ENCODE_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_HASH_KEY=

# Firebase / FCM notifications (optional)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FCM_TOPIC_SIGNALS=signals

# OAuth (optional login helpers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram mini app OAuth
BOT_TOKEN

# Redis caching (CacheRequestMiddleware + dedupe)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=20
REDIS_SSL=false

# Token cache tuning (used by token_price_cache)
TOKEN_CACHE_ENABLE_BACKGROUND_REFRESH=false
TOKEN_CACHE_REFRESH_INTERVAL=15
TOKEN_CACHE_INFO_TTL=3600
TOKEN_CACHE_PRICE_TTL=30

# Optional helpers
GPT_KEY=
COINGECKO_API_KEY=
SYMBOL_MOBILE_SUPPORT=

# Binance websocket manager
BINANCE_WS_INTERVAL=1m
BINANCE_WS_POLL_INTERVAL_SECONDS=60
BINANCE_WS_SYMBOL_REFRESH_MINUTES=60
